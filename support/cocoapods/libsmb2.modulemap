framework module SMB2 [system] [extern_c] {
    config_macros HAVE_STDINT_H, HAVE_TIME_H

    header "smb2-errors.h"
    header "smb2.h"
    header "smb2-ioctl.h"
    header "libsmb2.h"
    header "libsmb2-dcerpc.h"
    header "libsmb2-dcerpc-lsa.h"
    header "libsmb2-dcerpc-srvsvc.h"

    explicit module Raw {
        header "libsmb2-raw.h"
    }

    export *
}
